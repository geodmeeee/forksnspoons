:{$PORT}

root * .
file_server
encode gzip zstd

# Force emulator-related files to never cache
@emulator_files { path *.wasm *.data *.mem *.symbols.json *.zip *.7z *.cue *.iso *.chd }
header @emulator_files Content-Type application/octet-stream
header @emulator_files Cache-Control "no-store, no-cache, must-revalidate, max-age=0, private"

# HTML/JS/CSS for emulator loader
@text_files { path *.html *.js *.css }
header @text_files Content-Type text/html; charset=utf-8
header @text_files Cache-Control "no-store, no-cache, must-revalidate, max-age=0, private"

# Security headers
header {
    Content-Security-Policy "default-src 'self'; img-src 'self' data: https: *; style-src 'self' 'unsafe-inline' https: *; script-src 'self' 'unsafe-inline' 'unsafe-eval' https: * blob:; connect-src 'self' https: * blob:; media-src 'self' https: * blob:; font-src 'self' data: https: *; object-src 'none'; frame-src 'self' https: * blob:;"
    Cross-Origin-Opener-Policy "same-origin"
    Cross-Origin-Embedder-Policy "require-corp"
    Referrer-Policy "no-referrer"
    X-Content-Type-Options "nosniff"
}